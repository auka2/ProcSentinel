# ProcSentinel v3 — Environment Variables
# Copy to .env and fill in your values:  cp .env.example .env

# Login credentials
PROCSENTINEL_USER=admin
PROCSENTINEL_PASS=procsentinel

# AbuseIPDB API key (optional) — get free key at https://www.abuseipdb.com/api
ABUSEIPDB_KEY=

# Set to 1 to enable verbose DEBUG output from runner.py
PROCSENTINEL_DEBUG=0
